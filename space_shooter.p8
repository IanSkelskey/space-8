pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- simple spaceship movement + draw
-- assumes your ship graphic is sprite 0 (top-left 8x8)

#include controls.lua
#include menu.lua
#include starfield.lua
#include ship.lua
#include moon.lua

game_state = "menu"

-- reset helper used by obstacles
function reset_game()
    starfield_init()
    ship_init()
    moon_init()
    menu_init()
    game_state = "menu"
end

function _init()
    starfield_init()
    ship_init()
    moon_init()
    menu_init()
end

function _update()
    update_starfield()
    if game_state == "menu" then
        update_menu()
    elseif game_state == "controls" then
        update_controls()
    elseif game_state == "game" then
        update_moon()
        update_ship()
    end
end

function _draw()
    cls(0)
    draw_starfield()
    if game_state == "menu" then
        draw_menu()
    elseif game_state == "controls" then
        draw_controls()
    elseif game_state == "game" then
        draw_moon()
        draw_ship()
    end
end
