pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- simple spaceship movement + draw
-- assumes your ship graphic is sprite 0 (top-left 8x8)

#include controls.lua
#include menu.lua
#include starfield.lua
#include ship.lua

game_state = "menu"

function _init()
    starfield_init()
    ship_init()
    menu_init()
end

function _update()
    update_starfield()
    if game_state == "menu" then
        update_menu()
    elseif game_state == "controls" then
        update_controls()
    elseif game_state == "game" then
        update_ship()
    end
end

function _draw()
    cls(0)
    draw_starfield()
    if game_state == "menu" then
        draw_menu()
    elseif game_state == "controls" then
        draw_controls()
    elseif game_state == "game" then
        draw_ship()
        -- tiny hint
        print("arrow keys to fly", 28, 120, 6)
    end
end
